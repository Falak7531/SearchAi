# =============================================================
# Frontend environment variables (Vite)
# =============================================================
# Vite only exposes vars prefixed with VITE_ to the browser.
# Copy this file to `.env` (local) or `.env.production` (build)
# and adjust per environment.
#
# DEV NOTE: in `npm run dev`, requests are proxied through Vite
# (see vite.config.js) so VITE_API_URL is IGNORED. You don't
# need it locally unless you bypass the proxy.
#
# PROD NOTE: after `npm run build`, the bundle calls the URL
# below directly — so the backend MUST allow this origin in CORS.
# =============================================================

# Backend base URL used in production builds
VITE_API_URL=http://127.0.0.1:8000
