# =============================================================
# Backend env (optional override of <repo>/.env)
# =============================================================
# Loading order (first match wins, override=False):
#   1. <repo>/.env            ← shared root env (recommended)
#   2. <repo>/backend/.env    ← optional backend-only override
#
# Both files are resolved by ABSOLUTE PATH in
# app/core/config.py and app/rag/config.py, so it does not
# matter which directory you launch uvicorn from.
# =============================================================

# Comma-separated list of origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DEBUG=true

# LLM (RAG generation)
GROQ_API_KEY=your_groq_key_here

# Search weights (must sum to 1.0)
SEMANTIC_WEIGHT=0.6
KEYWORD_WEIGHT=0.4
